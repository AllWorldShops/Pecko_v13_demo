<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_usd_partner" model="ir.ui.view">
        <field name="name">view.partner.form.usd.partner</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']/group[@name='container_row_2']/group[@name='sale']/field[@name='user_id']" position="after">
                <field name="is_pecko_usd"/>
            </xpath>
            <xpath expr="//group/group/field[@name='vat']" position="after">
                <field name="trading_type"/>
            </xpath>
        </field>
    </record>
     <record id="view_company_form_aws" model="ir.ui.view">
        <field name="name">view.company.form.aws</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='general_info']/group/group/field[@name='mobile']" position="after">
                <field name="is_aws_company"/>
            </xpath>
        </field>
    </record>
</odoo>