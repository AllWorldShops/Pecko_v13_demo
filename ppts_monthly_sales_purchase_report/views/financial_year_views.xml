<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="from_view_financial_year" model="ir.ui.view">
        <field name="name">from.view.financial.year</field>
        <field name="model">financial.year</field>
        <field name="arch" type="xml">
            <form string="Financial Year">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="tree_view_financial_year" model="ir.ui.view">
        <field name="name">tree.view.financial.year</field>
        <field name="model">financial.year</field>
        <field name="arch" type="xml">
            <list string="Financial Year">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_view_financial_year" model="ir.actions.act_window">
        <field name="name">Financial Year</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">financial.year</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem  id="menu_parent_financial_year" name="Financial Year Master"
              parent="account.menu_finance_configuration" sequence="105">
    <menuitem action="action_view_financial_year" id="menu_financial_year"
               sequence="1"/>
    </menuitem>
</odoo>