<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_journal_form_debit_note" model="ir.ui.view">
        <field name="name">view.account.journal.form.debit.note</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='bank_account']/group/group/field[@name='code']" position="after">
                <field name="is_credit_journal"/>
            </xpath>
        </field>
    </record>
</odoo>