<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="credit_invoice_notes_state" model="ir.actions.act_window">
            <field name="name">Invoice/Credit Notes</field>
            <field name="res_model">account.move</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="account.view_out_invoice_tree"/>
            <field name="search_view_id" ref="account.view_account_invoice_filter"/>
            <field name="domain">['|',('move_type', '=', 'out_invoice'),('move_type', '=', 'out_refund')]</field>
             <field name="context">{'default_move_type': 'out_invoice'}</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Create a customer invoice
              </p><p>
                Create invoices, register payments and keep track of the discussions with your customers.
              </p>
            </field>
        </record>

        <record id="bill_refund_notes_state" model="ir.actions.act_window">
                <field name="name">Bills/Refunds</field>
                <field name="res_model">account.move</field>
                <field name="view_mode">list</field>
                <field name="view_id" ref="account.view_in_invoice_tree"/>
                <field name="search_view_id" ref="account.view_account_bill_filter"/>
                <field name="domain">['|',('move_type', '=', 'in_invoice'),('move_type', '=', 'in_refund')]</field>
                 <field name="context">{'default_move_type': 'in_invoice'}</field>
                <field name="help" type="html">
                  <p class="o_view_nocontent_smiling_face">
                    Create a customer Bill
                  </p><p>
                    Create Bill, register payments and keep track of the discussions with your Vendor.
                  </p>
                </field>
        </record>
</odoo>

