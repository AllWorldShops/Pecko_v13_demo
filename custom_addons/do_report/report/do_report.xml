                                </div>
                            </span>
                        </div>
                        <div class="col-3" style="text-align:right;position:relative;">
                            <img t-if="o.company_id.logo_one"
                                 t-att-src="image_data_uri(o.company_id.logo_one)"
                                 style="width:122px;height:122px;position:relative;top:-70px;" alt="Logo"/>
                        </div>

                    </div>

                    <div class="col-6"
                         style="position:relative; bottom:14px; left:25%; transform:translateX(-50%); text-align:center;">
                        <div class="text-muted" style="font-family: Calibri; color: black;">
                            <t t-if="user.lang == 'zh_CN'">页:</t>
                            <t t-else="">Page:</t>
                            <span class="page"/>
                            <t t-if="user.lang == 'zh_CN'">/</t>
                            <t t-else="">of</t>
                            <span class="topage"/>
                        </div>
                        <div class="clearfix mb8"/>
                    </div>

                    <div style="text-align:right">
                        <t t-if="o.company_id.country_id.code != 'SG'">
                            <span>
                                <t t-if="user.lang == 'zh_CN'">用户:</t>
                                <t t-else="">user:</t>
                            </span>
                            <span t-esc="user.name"/>
                        </t>
                    </div>
                </div>
            </div>
        </template>

        <template id="custom_do_external_layout">
            <!-- Multicompany -->
            <t t-if="not o and doc">
                <t t-set="o" t-value="doc"/>
            </t>

            <t t-if="o and 'company_id' in o">
                <t t-set="company" t-value="o.company_id.sudo()"/>
            </t>
            <t t-if="not o or not 'company_id' in o">
                <t t-set="company" t-value="res_company"/>
            </t>

            <t t-call="do_report.custom_do_external_layout_background">
                <t t-raw="0"/>
            </t>
        </template>

        <record id="paperformat_do" model="report.paperformat">
            <field name="name">Do Paperformat</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">1</field>
            <field name="margin_bottom">31</field>
            <field name="margin_left">6</field>
            <field name="margin_right">6</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">30</field>
            <field name="dpi">90</field>
        </record>


        <record id="action_do_report_picking" model="ir.actions.report">
            <field name="name">Do Report</field>
            <field name="model">stock.picking</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">do_report.report_custom_do</field>
            <field name="report_file">do_report.report_custom_do</field>
            <field name="paperformat_id" ref="do_report.paperformat_do"/>
            <field name="binding_model_id" ref="stock.model_stock_picking"/>
            <field name="binding_type">report</field>
        </record>


    </data>
</odoo>
