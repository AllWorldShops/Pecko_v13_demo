<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="custom_invoice_external_layout_background">
            <div class="header o_background_header">
                <div class="row" style="bottom:10px;top:10px">
                    <div class="col-10">
                        <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                             alt="Logo"/>
                        <div class="company_address" style="line-height:10px;font-family: Calibri;">
                            <div style="font-size:11px;line-height:16px">
                                <strong>
                                    <span style="font-size: 25px;" t-field="company.partner_id.name"/>
                                </strong>
                                <br/>
                                <!--                                <span t-field="o.company_id.street" />-->
                                <t t-if="o.company_id.street">
                                    <span t-field="o.company_id.street"/>,
                                    <br/>
                                </t>
                                <t t-if="o.company_id.street2">
                                    <span t-field="o.company_id.street2"/>,
                                    <br/>
                                </t>

                                <t t-if="o.company_id.country_id.code != 'SG'">
                                    <span t-field="o.company_id.city"/>
                                    ,
                                </t>
                                <span t-field="o.company_id.state_id"/>
                                <span t-field="o.company_id.country_id"/>
                                -
                                <span t-field="o.company_id.zip"/>
                                <br/>
                                <span>TEL :</span>
                                <span t-field="o.company_id.phone"/>
                                <br/>
                                <t t-if="o.company_id.country_id.code != 'SG'">
                                    <span>E-mail:</span>
                                    <span t-field="o.company_id.email"/>
                                    ,
                                </t>
                                <span>URL:</span>
                                <span t-field="o.company_id.website"/>
                                <br/>
                                <span>Company Reg No:</span>
                                <span t-field="o.company_id.company_registry"/>
                                <br/>
                                <span>GST Registration:</span>
                                <span t-field="o.company_id.vat"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-2">
                        <div class="text-muted text-right">
                            <t t-if="user.lang == 'zh_CN'">
                                页数:
                                <span class="page"/>
                                /
                                <span class="topage"/>
                            </t>
                            <t t-else="">
                                Page:
                                <span class="page"/>
                                of
                                <span class="topage"/>
                            </t>
                        </div>
                        <div class="clearfix mb8"/>
                    </div>
                </div>
            </div>

            <div class="article o_report_layout_background" t-att-data-oe-model="o and o._name"
                 t-att-data-oe-id="o and o.id">
                <t t-raw="0"/>
            </div>


            <div class="footer o_background_footer" style="font-family: Calibri;font-size:12px;">
                <t t-if="o.company_id.country_id.code != 'CN'">
                    <t t-if="o.company_id.country_id.code != 'CN'">
                        <table width="100%"
                               style="border-top: 1px solid black;border-bottom: 1px solid black;font-size:10px;height:15px;"
                               class="table table-borderless">
                            <tr style="height:5px;">
                                <td width="25%">
                                    <t t-if="user.lang == 'zh_CN'">仅用于税务目的（人民币）</t>
                                    <t t-else="">For Tax Purpose in CNY Only</t>
                                </td>
                                <td width=""></td>
                                <td width="10%"></td>
                                <td width="15%" style="text-align:right;">
                                    <t t-if="user.lang == 'zh_CN'">净总额（人民币）</t>
                                    <t t-else="">Net Total (CNY)</t>
                                </td>
                                <td width="" style="text-align:right;">:</td>
                                <!--                                <td width="15%">-->
                                <!--                                    <t t-if="o.get_net_amount_report()">-->
                                <!--                                        <span t-esc="'%.2f' % (o.get_net_amount_report())"/>-->
                                <!--                                    </t>-->
                                <!--                                    <t t-else="">-->
                                <!--                                        <span>-</span>-->
                                <!--                                    </t>-->
                                <!--                                </td>-->

                                <td width="15%" style="text-align:right;">
                                    <t t-if="user.lang == 'zh_CN'">
                                        净总额（<span t-field="o.currency_id"/>）
                                    </t>
                                    <t t-else="">
                                        Net Total (<span t-field="o.currency_id"/>)
                                    </t>
                                </td>

                                <td width="1%" style="text-align:left;">:</td>
                                <td width="15%" style="text-align:right;">
                                    <span t-esc="'%.2f'%(o.amount_untaxed)"/>
                                </td>
                            </tr>
                            <tr style="height:5px;">
                                <td width="15%">1 CNY =
                                    <span t-field="o.invoice_currency_rate"/>
                                    USD
                                </td>
                                <td width="3.3%"></td>
                                <td width="15%"></td>
                                <td width="15%" style="text-align:right;">
                                    <t t-if="user.lang == 'zh_CN'">税额</t>
                                    <t t-else="">Tax Amount</t>
                                </td>
                                <td width="3" style="text-align:right;">:</td>
                                <t t-if="o.invoice_currency_rate">
                                    <span t-esc="'%.2f' % (o.amount_tax / o.invoice_currency_rate)"/>
                                </t>
                                <t t-else="">
                                    <span>0.00</span>
                                </t>

                                <td width="16%" style="text-align:right;">
                                    <t t-if="user.lang == 'zh_CN'">税额</t>
                                    <t t-else="">Tax Amount</t>
                                </td>
                                <td width="1%" style="text-align:left;">:</td>
                                <td width="15%" style="text-align:right;">
                                    <span style="text-align:right;" t-esc="'%.2f'%(o.amount_tax)"/>
                                </td>
                            </tr>
                            <tr style="height:5px">
                                <td width="15%">
                                    <t t-if="user.lang == 'zh_CN'">
                                        汇率 =
                                    </t>
                                    <t t-else="">
                                        Conversation Rate =
                                    </t>
                                    <span t-field="o.invoice_currency_rate"/>
                                </td>

                                <td width="3.3%"></td>
                                <td width="15%"></td>

                                <td width="15%" style="text-align:right;">
                                    <t t-if="user.lang == 'zh_CN'">
                                        总计 (CNY)
                                    </t>
                                    <t t-else="">
                                        Grand Total (CNY)
                                    </t>
                                </td>

                                <td width="3%" style="text-align:right;">:</td>

                                <t t-if="o.invoice_currency_rate">
                                    <span style="padding-left:3px"
                                          t-esc="'%.2f' % (((o.amount_tax or 0) / o.invoice_currency_rate) + o.get_net_amount_report())"/>
                                </t>
                                <t t-else="">
                                    <span style="color:red;padding-left:3px;">
                                        <t t-if="user.lang == 'zh_CN'">0.00（无效汇率）</t>
                                        <t t-else="">0.00 (Invalid exchange rate)</t>
                                    </span>
                                </t>

                                <td width="16%" style="text-align:right;">
                                    <t t-if="user.lang == 'zh_CN'">
                                        总计 (
                                    </t>
                                    <t t-else="">
                                        Grand Total (
                                    </t>
                                    <span t-field="o.currency_id"/>
                                    )
                                </td>

                                <td width="1%" style="text-align:left;">:</td>

                                <td width="15%" style="text-align:right;">
                                    <span t-esc="'%.2f'%(o.amount_total)"/>
                                </td>
                            </tr>

                        </table>
                    </t>
                    <!--                    <p style="page-break-after:always"></p>-->
                </t>
                <table style='width:100%;background:transparent;'>
                    <tr
                            style='background-color: white;background:transparent !important;'>
                        <td>
                        </td>
                    </tr>
                </table>
                <style>
                </style>
                <t t-if="o.company_id.country_id.code == 'CN'">
                    <t t-if="o.company_id.country_id.code == 'CN'">
                        <table width="100%"
                               style="margin-bottom:10px;border-top: 1px solid black;border-bottom: 1px solid black;font-size:px;height:15px"
                               class="table table-borderless">
                            <tr style="height:5px;">
                                <td width="25%">
                                    <t t-if="user.lang == 'zh_CN'">仅用于税务目的（人民币）</t>
                                    <t t-else="">For Tax Purpose in CNY Only</t>
                                </td>
                                <td width=""></td>
                                <td width="10%"></td>
                                <td width="15%" style="text-align:right;">
                                    <t t-if="user.lang == 'zh_CN'">净总额（人民币）</t>
                                    <t t-else="">Net Total (CNY)</t>
                                </td>
                                <td width="" style="text-align:right;">:</td>
                                <td width="15%">
                                    <span t-esc="'%.2f'%(o.amount_untaxed * o.invoice_currency_rate)"/>
                                </td>
                                <td width="15%" style="text-align:right;">
                                    <t t-if="user.lang == 'zh_CN'">
                                        净总额（<span t-field="o.currency_id"/>）
                                    </t>
                                    <t t-else="">
                                        Net Total (<span t-field="o.currency_id"/>)
                                    </t>
                                </td>
                                <td width="1%" style="text-align:left;">:</td>
                                <td width="15%" style="text-align:right;">
                                    <span t-esc="'%.2f'%(o.amount_untaxed)"/>
                                </td>
                            </tr>
                            <tr style="height:5px;">
                                <td width="15%">1 USD =
                                    <span t-field="o.invoice_currency_rate"/>
                                    CNY
                                </td>
                                <td width="3.3%"></td>
                                <td width="15%"></td>
                                <td width="15%" style="text-align:right;">
                                    <t t-if="user.lang == 'zh_CN'">税额</t>
                                    <t t-else="">Tax Amount</t>
                                </td>
                                <td width="5%" style="text-align:right;">:</td>
                                <td width="15%">
                                    <span style="padding:8px" t-esc="'%.2f'%(o.amount_tax * o.invoice_currency_rate)"/>
                                </td>
                                <td width="16%" style="text-align:right;">
                                    <t t-if="user.lang == 'zh_CN'">税额</t>
                                    <t t-else="">Tax Amount</t>
                                </td>
                                <td width="1%" style="text-align:left;">:</td>
                                <td width="15%" style="text-align:right;">
                                    <span style="text-align:right;" t-esc="'%.2f'%(o.amount_tax)"/>
                                </td>
                            </tr>
                            <tr style="height:5px">
                                <td width="15%">
                                    <t t-if="user.lang == 'zh_CN'">汇率 =</t>
                                    <t t-else="">Conversation Rate =</t>
                                    <span t-field="o.invoice_currency_rate"/>
                                    CNY
                                </td>

                                <td width="3.3%"></td>
                                <td width="15%"></td>

                                <td width="15%" style="text-align:right;">
                                    <t t-if="user.lang == 'zh_CN'">总计 (CNY)</t>
                                    <t t-else="">Grand Total (CNY)</t>
                                </td>

                                <td width="5%" style="text-align:right;">:</td>

                                <td width="15%">
                                    <span t-esc="'%.2f'%((o.amount_tax * o.invoice_currency_rate) + (o.amount_untaxed * o.invoice_currency_rate))"/>
                                </td>

                                <td width="15%" style="text-align:right;">
                                    <t t-if="user.lang == 'zh_CN'">总计 (</t>
                                    <t t-else="">Grand Total (</t>
                                    <span t-field="o.currency_id"/>)
                                </td>

                                <td width="1%" style="text-align:left;">:</td>

                                <td width="15%" style="text-align:right;">
                                    <span t-esc="'%.2f'%(o.amount_total)"/>
                                </td>
                            </tr>

                        </table>
                    </t>


                    <table width="100%" style="border-bottom: 1px solid black;position:relative;line-height:1.5;"
                           class="table table-borderless">
                        <tr>
                            <td width="15%" style="vertical-align: top; padding-top: 20px; padding-left: 750px;">
                                <img t-if="o.company_id.logo_three"
                                     t-att-src="image_data_uri(o.company_id.logo_three)"
                                     style="width:110px; display: block;"
                                     alt="Logo"/>
                            </td>
                        </tr>

                    </table>
                </t>
            </div>
        </template>
        <template id="custom_invoice_external_layout">
            <!-- Multicompany -->
            <t t-if="not o and doc">
                <t t-set="o" t-value="doc"/>
            </t>
            <t t-if="o and 'company_id' in o">
                <t t-set="company" t-value="o.company_id.sudo()"/>
            </t>
            <t t-if="not o or not 'company_id' in o">
                <t t-set="company" t-value="res_company"/>
            </t>

            <t t-call="invoice_report.custom_invoice_external_layout_background">
                <t t-raw="0"/>
            </t>
        </template>

        <record id="paperformat_invoice" model="report.paperformat">
            <field name="name">Invoice Paperformat</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">55</field>
            <field name="margin_bottom">70</field>
            <field name="margin_left">6</field>
            <field name="margin_right">6</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">49</field>
            <field name="dpi">90</field>
        </record>

        <!-- QWeb Reports -->

        <record id="account_invoice_ppts" model="ir.actions.report">
            <field name="name">Invoice Report</field>
            <field name="model">account.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">invoice_report.report_ppts_invoice_custom</field>
            <field name="report_file">invoice_report.report_ppts_invoice_custom</field>
            <field name="paperformat_id" ref="invoice_report.paperformat_invoice"/>
            <field name="print_report_name">(object._get_report_base_filename())</field>
            <field name="attachment">(object.state in ('draft','open','paid')) and ('INV'+(object.name or
                '').replace('/','')+'.pdf')
            </field>
            <field name="binding_model_id" ref="account.model_account_move"/>
        </record>

    </data>
</odoo>
