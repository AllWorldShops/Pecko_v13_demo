<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_so_report">
        <t t-if="not o and doc">
            <t t-set="o" t-value="doc"/>
        </t>
        <t t-if="o and 'company_id' in o">
            <t t-set="company" t-value="o.company_id.sudo()"/>
        </t>
        <t t-if="not o or not 'company_id' in o">
            <t t-set="company" t-value="res_company"/>
        </t>
        <div class="header o_background_header">
            <div class="row" style="bottom:1px;top:1px">
                <div class="col-8" style="bottom:14px;">
                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)"
                         alt="Logo"/>
                    <div class="company_address"
                         style="line-height:10px;font-family: Calibri;text-color:black;">
                        <div>
                            <strong>
                                <span style="font-size: 20px;"
                                      t-field="company.partner_id.name"/>
                            </strong>
                            <br/>
                            <br/>

                            <span style="font-size: 14px;" t-field="o.company_id.street"/>,
                            <t t-if="o.company_id.street1">,
                                <span style="font-size: 14px;" t-field="o.company_id.street1"/>,
                                <br/>
                                <span style="font-size: 14px;" t-field="o.company_id.street2"/>
                            </t>
                            <t t-else="">
                                <span style="font-size: 14px;" t-field="o.company_id.street2"/>
                            </t>
                            <br/>
                            <br/>
                            <t t-if="o.company_id.country_id.code != 'SG'">
                                <span style="font-size: 14px;" t-field="o.company_id.city"/>
                                ,
                            </t>
                            <span style="font-size: 14px;" t-field="o.company_id.state_id"/>

                            <span style="font-size: 14px;" t-field="o.company_id.country_id"/>
                            -
                            <span style="font-size: 14px;" t-field="o.company_id.zip"/>
                            <br/>
                            <br/>
                            <span style="font-size: 14px;">TEL :</span>
                            <span style="font-size: 14px;" t-field="o.company_id.phone"/>
                            <t t-if="o.company_id.fax">
                                |
                                <span style="font-size: 14px;">FAX :</span>
                                <span style="font-size: 14px;" t-field="o.company_id.fax"/>
                            </t>
                            <br/>
                            <br/>
                            <t style="font-size: 14px;" t-if="o.company_id.country_id.code != 'SG'">
                                <span style="font-size: 14px;">E-mail:</span>
                                <span style="font-size: 14px;" t-field="o.company_id.email"/>
                                ,
                            </t>
                            <span style="font-size: 14px;">URL:</span>
                            <span style="font-size: 14px;" t-field="o.company_id.website"/>
                            <br/>
                            <br/>
                            <span style="font-size: 14px;">Company Reg No:</span>
                            <span style="font-size: 14px;" t-field="o.company_id.company_registry"/>
                        </div>
                    </div>
                </div>
                <div class="col-4" style="position: relative; padding-top: 30px; text-align: right;">
                    <div class="text-muted" style="font-family: Calibri; color: black;">
                        <t t-if="user.lang == 'zh_CN'">
                            页数：
                            <span class="page"/>
                            /
                            <span class="topage"/>
                        </t>
                        <t t-else="">
                            Page:
                            <span class="page"/>
                            of
                            <span class="topage"/>
                        </t>
                    </div>
                    <div class="clearfix mb8"/>
                </div>

            </div>
        </div>
        <div class="article o_report_layout_background">
            <t t-raw="0"/>
        </div>
        <div class="footer o_background_footer" style="margin-bottom:280px">
            <table width="100%" class="table table-borderless">
                <tr>
                    <td>
                        <div style="text-align:center;font-size:13px;color:#484848;position:relative; top:17px;">
                            <strong>
                                <t t-if="user.lang == 'zh_CN'">
                                    **这是计算机生成的文件，无需签名。**
                                </t>
                                <t t-else="">
                                    **This is a computer generated document. Signature is not required.**
                                </t>
                            </strong>
                        </div>
                        <br/>
                    </td>
                </tr>

            </table>

            <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo_four)" alt="Logo"
                 style="position:relative; bottom:54px; left:730px; width:130px;"/>

            <div style="text-align:right">

                <span>user:</span>
                <span t-esc="user.name"/>
            </div>
        </div>
    </template>

    <template id="external_layout_po_report">

        <t t-if="not o and doc">
            <t t-set="o" t-value="doc"/>
        </t>
        <t t-if="o and 'company_id' in o">
            <t t-set="company" t-value="o.company_id.sudo()"/>
        </t>
        <t t-if="not o or not 'company_id' in o">
            <t t-set="company" t-value="res_company"/>
        </t>
        <div class="header o_background_header">
            <div class="row" style="bottom:1px;top:1px">
                <div class="col-8">
                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" alt="Logo"/>
                    <br/>
                    <br/>
                    <div class="company_address" style="line-height:5px;font-size: 10px;font-family: Calibri;ftext-color:black;">
                        <div>
                            <strong>
                                <span style="font-size: 20px;" t-field="company.partner_id.name"/>
                            </strong>
                            <br/>
                            <br/>
                            <br/>
                            <br/>

                            <span style="font-size: 14px;" t-field="o.company_id.street"/>,
                            <t t-if="o.company_id.street1">
                                <span style="font-size: 14px;" t-field="o.company_id.street1"/>,

                                <br/>
                                <br/>
                                <br/>
                                <span style="font-size: 14px;" t-field="o.company_id.street2"/>,
                            </t>
                            <t t-else="">
                                <span style="font-size: 14px;" t-field="o.company_id.street2"/>,
                            </t>
                            <br/>
                            <br/>
                            <br/>
                            <br/>
                            <t t-if="o.company_id.country_id.code != 'SG'">
                                <span style="font-size: 14px;" t-field="o.company_id.city"/>
                                ,
                            </t>
                            <span style="font-size: 14px;" t-field="o.company_id.state_id"/>

                            <span style="font-size: 14px;" t-field="o.company_id.country_id"/>
                            -
                            <span style="font-size: 14px;" t-field="o.company_id.zip"/>
                            <br/>
                            <br/>
                            <br/>
                            <br/>
                            <span style="font-size: 14px;">TEL :</span>
                            <span style="font-size: 14px;" t-field="o.company_id.phone"/>
                            <t t-if="o.company_id.fax">
                                |
                                <span style="font-size: 14px;">FAX :</span>
                                <span style="font-size: 14px;" t-field="o.company_id.fax"/>
                            </t>
                            <br/>
                            <br/>
                            <br/>
                            <br/>
                            <t t-if="o.company_id.country_id.code != 'SG'">
                                <span style="font-size: 14px;">E-mail:</span>
                                <span style="font-size: 14px;" t-field="o.company_id.email"/>
                                ,
                            </t>
                            <span style="font-size: 14px;">URL:</span>
                            <span style="font-size: 14px;" t-field="o.company_id.website"/>
                            <br/>
                            <br/>
                            <br/>
                            <br/>
                            <span style="font-size: 14px;">Company Reg No:</span>
                            <span style="font-size: 14px;" t-field="o.company_id.company_registry"/>
                        </div>
                    </div>
                </div>
                <div class="col-4" style="position: relative; bottom: 14px; text-align: right;">
                    <div class="text-muted" style="font-family: Calibri; color: black;">
                        <t t-if="user.lang == 'zh_CN'">
                            页数：
                            <span class="page"/>
                            /
                            <span class="topage"/>
                        </t>
                        <t t-else="">
                            Page:
                            <span class="page"/>
                            of
                            <span class="topage"/>
                        </t>
                    </div>
                    <div class="clearfix mb8"/>
                </div>

            </div>
        </div>

        <div class="article o_report_layout_background">
            <t t-raw="0"/>
        </div>

        <div class="footer o_background_footer">

             <table class="table table-sm table-borderless" style="width:100%; font-size:13px; border-collapse: collapse; margin-top:20px;">

                <tr>
                    <td style="width:30%;">制单</td>
                    <td style="width:25%;">确认</td>
                    <td style="width:20%;">批准</td>
                    <td style="width:20%;">供应商回签</td>
                    </tr>
                </table>


    <!-- Contact Info Footer -->
            <div style="font-size:13px; text-align:center; border-top:1px solid black; padding-top:5px;">
                Phone: +86(512)57877211   
                Email: orders@pecko.com   
                Web: http://www.pecko.com
                <br/>
                <span style="font-size:11px;">Page: <span class="page"/> / <span class="topage"/></span>
            </div>
        </div>

    </template>

    <template id="inherit_report_saleorder_document"
              inherit_id="sale.report_saleorder_document">

        <xpath expr="//t[@t-call='web.external_layout']"
               position="replace">
            <t t-call="pecko_so_po_report.external_layout_so_report">
                <div class="page" style="font-family: Calibri;text-color:black;">
                    <div style="position:relative;">
                        <div style="font-size: 20px; text-align: center;">
                            <span>
                                <strong>
                                    <t t-if="user.lang == 'zh_CN'">销售订单</t>
                                    <t t-else="">SALES ORDER</t>
                                </strong>
                            </span>
                        </div>

                        <br/>
                        <div class="row" style="font-size:13px">
                            <div class="col-6">
                                <strong>
                                    <span t-field="doc.partner_id.name"/>
                                </strong>
                                <br/>
                                <span t-field="doc.partner_id.street"/>
                                <span t-field="doc.partner_id.street2"/>
                                <br/>
                                <span t-field="doc.partner_id.city"/>
                                <span t-field="doc.partner_id.state_id"/>
                                <br/>
                                <span t-field="doc.partner_id.country_id"/>
                                <span t-field="doc.partner_id.zip"/>
                                <br/>
                                <t t-if="user.lang == 'zh_CN'">电话:</t>
                                <t t-else="">Phone:</t>
                                <span t-field="doc.partner_id.phone"/>
                                <br/>
                                <t t-if="user.lang == 'zh_CN'">邮箱:</t>
                                <t t-else="">Email:</t>
                                <span style="word-break: break-all;" t-field="doc.partner_id.email"/>
                            </div>
                            <div class="col-1"/>
                            <div class="col-5">
                                <div class="row" style="background-color: #f4f4f5;">
                                    <div class="col-6">
                                        <strong>
                                            <t t-if="user.lang == 'zh_CN'">销售订单号</t>
                                            <t t-else="">SALES ORDER NO</t>
                                        </strong>
                                    </div>
                                    <div class="col-6">
                                        <span t-field="doc.name" style="text-align:left"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-6">
                                        <strong>
                                            <t t-if="user.lang == 'zh_CN'">客户采购单号</t>
                                            <t t-else="">CUSTOMER PO NO</t>
                                        </strong>
                                    </div>
                                    <div class="col-6">
                                        <span t-field="doc.customer_po_no" style="text-align:left"/>
                                    </div>
                                </div>
                                <div class="row" style="background-color: #f4f4f5;">
                                    <div class="col-6">
                                        <strong>
                                            <t t-if="user.lang == 'zh_CN'">下单日期</t>
                                            <t t-else="">DATE ORDER</t>
                                        </strong>
                                    </div>
                                    <div class="col-6">
                                        <span t-field="doc.date_order" style="text-align:left"
                                              t-options='{"format":"dd/MM/yyyy"}'/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-6">
                                        <strong>
                                            <t t-if="user.lang == 'zh_CN'">付款条款</t>
                                            <t t-else="">PAYMENT TERM</t>
                                        </strong>
                                    </div>
                                    <div class="col-6">
                                        <span t-field="doc.payment_term_id.name" style="text-align:left"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <br/>
                        <br/>
                        <table class="table table-sm table-borderless" style="table-layout:fixed;">
                            <style>
                                tbody tr:nth-child(odd){
                                background-color: #f4f4f5;
                                }
                                th{font-size:13px}
                                td{font-size:13px}
                            </style>
                            <thead>
                                <tr style="border-top:1px solid black;border-bottom:1px solid black;">
                                    <t t-set="colspan" t-value="5"/>
                                    <th class="text-left" style="width:4%;color:#875A7B">
                                        <t t-if="user.lang == 'zh_CN'">序号</t>
                                        <t t-else="">NO</t>
                                    </th>
                                    <th class="text-left" style="width:20%;color:#875A7B">
                                        <t t-if="user.lang == 'zh_CN'">Pecko 部件号</t>
                                        <t t-else="">PECKO PART NUMBER</t>
                                    </th>
                                    <th class="text-left" style="width:15%;color:#875A7B">
                                        <t t-if="user.lang == 'zh_CN'">部件号</t>
                                        <t t-else="">PART NUMBER</t>
                                    </th>
                                    <th class="text-left" style="width:15%;color:#875A7B">
                                        <t t-if="user.lang == 'zh_CN'">描述</t>
                                        <t t-else="">DESCRIPTION</t>
                                    </th>
                                    <th class="text-center" style="width:10%;color:#875A7B">
                                        <t t-if="user.lang == 'zh_CN'">数量</t>
                                        <t t-else="">QUANTITY</t>
                                    </th>
                                    <th class="text-center" style="width:13%;color:#875A7B">
                                        <t t-if="user.lang == 'zh_CN'">需求日期</t>
                                        <t t-else="">NEED DATE</t>
                                    </th>
                                    <th class="text-right" style="width:8%;color:#875A7B">
                                        <t t-if="user.lang == 'zh_CN'">单价</t>
                                        <t t-else="">PRICE</t>
                                    </th>
                                    <th t-if="display_discount" class="text-right" style="width:10%;color:#875A7B"
                                        groups="sale.group_discount_per_so_line">
                                        <t t-if="user.lang == 'zh_CN'">折扣(%)</t>
                                        <t t-else="">DISC.(%)</t>
                                        <t t-set="colspan" t-value="colspan+1"/>
                                    </th>
                                    <t t-if="doc.amount_tax > 0">
                                        <th class="text-end" style="width:10%;color:#875A7B;">
                                            <t t-if="user.lang == 'zh_CN'">税额</t>
                                            <t t-else="">TAXES</t>
                                        </th>
                                    </t>
                                    <th class="text-end" style="width:15%;color:#875A7B">
                                        <t t-if="user.lang == 'zh_CN'">总金额</t>
                                        <t t-else="">AMOUNT TOTAL</t>
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="sale_tbody">

                                <t t-set="current_subtotal" t-value="0"/>
                                <t t-set="i" t-value="1"/>

                                <t t-foreach="doc.order_line" t-as="line">

                                    <t t-set="current_subtotal"
                                       t-value="current_subtotal + line.price_subtotal"
                                    />
                                    <t t-set="current_subtotal"
                                       t-value="current_subtotal + line.price_total"
                                       groups="account.group_show_line_subtotals_tax_included"/>

                                    <tr
                                            t-att-class="'bg-200 font-weight-bold' if line.display_type == 'line_section' else 'font-italic' if line.display_type == 'line_note' else ''">
                                        <t t-if="not line.display_type">
                                            <td>
                                                <span t-field="line.line_no"/>
                                            </td>
                                            <td>
                                                <span t-field="line.product_id.default_code"/>
                                            </td>

                                            <td>
                                                <span t-field="line.customer_part_no"/>
                                            </td>
                                            <td>
                                                <span t-field="line.name"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="line.product_uom_qty"/>
                                                <span t-field="line.product_uom"/>
                                            </td>

                                            <td class="text-center">
                                                <span t-field="line.requested_date_line"
                                                      t-options='{"format":"dd-MM-yyyy"}'/>
                                            </td>
                                            <td class="text-right">
                                                <span t-field="line.price_unit"/>
                                            </td>
                                            <td t-if="display_discount" class="text-right"
                                                groups="sale.group_discount_per_so_line">
                                                <span t-field="line.discount"/>
                                            </td>
                                            <t t-if="doc.amount_tax>0">
                                                <td class="text-right">
                                                    <span t-esc="line.tax_id.code"/>
                                                </td>
                                            </t>
                                            <td class="text-end">
                                                <span t-field="line.price_subtotal"
                                                />
                                                <span t-field="line.price_total"
                                                />
                                            </td>
                                        </t>
                                        <t t-if="line.display_type == 'line_section'">
                                            <td t-att-colspan="colspan">
                                                <span t-field="line.name"/>
                                            </td>
                                            <t t-set="current_section" t-value="line"/>
                                            <t t-set="current_subtotal" t-value="0"/>
                                        </t>
                                        <t t-if="line.display_type == 'line_note'">
                                            <td t-att-colspan="colspan">
                                                <span t-field="line.name"/>
                                            </td>
                                        </t>
                                    </tr>
                                    <t t-set="i" t-value="i+1"/>

                                </t>
                            </tbody>
                        </table>
                        <div class="clearfix">
                            <div class="row" name="total">
                                <div class="col-8"/>
                                <div
                                        t-attf-class="#{'col-4' if report_type != 'html' else 'col-sm-7 col-md-5'} ml-auto">
                                    <table class="table table-sm table-borderless"
                                           style="border-top:1px solid #dddddd;">

                                        <t t-foreach="doc.amount_by_group" t-as="amount_by_group">
                                            <tr style="border-bottom:1px solid #dddddd;">

                                                <t
                                                        t-if="amount_by_group[3] == 1 and doc.amount_untaxed == amount_by_group[2]">

                                                    <td class="text-end">
                                                        <span t-esc="amount_by_group[0]"/>
                                                        <span>
                                                            &amp;nbsp;
                                                            <span>on</span>
                                                            &amp;nbsp;
                                                            <t t-esc="amount_by_group[2]"
                                                               t-options='{"widget": "monetary", "display_currency": doc.pricelist_id.currency_id}'/>
                                                        </span>
                                                    </td>
                                                    <td class="text-end">
                                                        <span t-esc="amount_by_group[1]"
                                                              t-options='{"widget": "monetary", "display_currency": doc.pricelist_id.currency_id}'/>
                                                    </td>
                                                </t>
                                                <t t-else="">
                                                    <td class="text-end">
                                                        <span t-esc="amount_by_group[0]"/>
                                                    </td>
                                                    <td class="text-end">
                                                        <span t-esc="amount_by_group[1]"
                                                              t-options='{"widget": "monetary", "display_currency": doc.pricelist_id.currency_id}'/>
                                                    </td>
                                                </t>
                                            </tr>
                                        </t>
                                        <tr class="border-black text-end"
                                            style="text-align: right;border-top:1px solid #dddddd;">
                                            <td style="font-size:13px">
                                                <strong>
                                                    <t t-if="user.lang == 'zh_CN'">
                                                        总计(
                                                        <span t-field="doc.pricelist_id.currency_id"/>):
                                                    </t>
                                                    <t t-else="">
                                                        Total(
                                                        <span t-field="doc.pricelist_id.currency_id"/>):
                                                    </t>
                                                </strong>
                                            </td>
                                            <td class="text-end">
                                                <span t-field="doc.amount_total"/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <br/>
                        <br/>

                    </div>

                </div>
            </t>
        </xpath>
    </template>

    <template id="inherit_report_purchaseorder_document" inherit_id="purchase.report_purchaseorder_document">

        <xpath expr="//t[@t-call='web.external_layout']" position="replace">
            <t t-call="pecko_so_po_report.external_layout_po_report">
                <div style="position:relative;top:30px;">
                    <div class="page" style="font-family: Calibri;text-color:black;">
                        <div style="font-size: 20px;text-align: center;">
                            <span>
                                <strong>
                                    <t t-if="user.lang == 'zh_CN'">采购订单</t>
                                    <t t-else="">PURCHASE ORDER</t>
                                </strong>
                            </span>
                        </div>

                        <br/>
                        <div width="100%">
                            <div style="float:left;font-size:13px">
                                <span>
                                    <strong>
                                        <t t-esc="o.partner_id.name"/>
                                    </strong>
                                </span>
                                <br/>
                                <span>
                                    <t t-esc="o.partner_id.street"/>
                                    <t t-esc="o.partner_id.street2"/>
                                </span>
                                <br/>
                                <span>
                                    <t t-esc="o.partner_id.city"/>
                                    <t t-esc="o.partner_id.state_id.name"/>
                                </span>
                                <br/>
                                <span>
                                    <t t-esc="o.partner_id.country_id.name"/>
                                    <t t-esc="o.partner_id.zip"/>
                                </span>
                                <br/>
                                <br/>
                                <span>
                                    <t t-if="user.lang == 'zh_CN'">收件人：</t>
                                    <t t-else="">ATTN :</t>
                                    <t t-esc="o.attn.name"/>
                                </span>
                                <br/>
                                <br/>
                                <div>
                                    <t t-if="user.lang == 'zh_CN'">请提供以下内容：</t>
                                    <t t-else="">Please supply the following :</t>
                                </div>
                            </div>

                            <div style="float:right;font-size:13px">
                                <span>
                                    <t t-if="user.lang == 'zh_CN'">采购订单号：</t>
                                    <t t-else="">PO NO :</t>
                                    <strong>
                                        <t t-esc="o.name"/>
                                    </strong>
                                </span>
                                <br/>

                                <span>
                                    <t t-if="user.lang == 'zh_CN'">日期：</t>
                                    <t t-else="">DATE :</t>
                                    <strong>
                                        <t t-if="o.state in ('draft','sent')">
                                            <span t-field="o.date_order" t-options="{&quot;format&quot;: &quot;dd-MM-yyyy&quot;}"/>
                                        </t>
                                        <t t-if="o.state in ('purchase','done')">
                                            <span t-field="o.date_approve" t-options="{&quot;format&quot;: &quot;dd-MM-yyyy&quot;}"/>
                                        </t>
                                    </strong>
                                </span>
                                <br/>

                                <span>
                                    <t t-if="user.lang == 'zh_CN'">旧采购订单号：</t>
                                    <t t-else="">Old PO Number:</t>
                                    <strong>
                                        <span t-field="o.old_po_no"/>
                                    </strong>
                                </span>
                            </div>
                        </div>


                        <table class="table table-sm table-borderless" style="width:100%; font-size:13px; border-collapse: collapse; margin-top:20px;                                                                                                                               ">

                            <style>
                                th{font-size:13px}
                                td{font-size:13px}
                            </style>
                            <thead>
                                <tr style="text-size:13px;width:100%">
                                    <t t-set="colspan" t-value="5"/>
                                    <th class="text-left" style="width:5%">
                                        <b>
                                            <t t-if="user.lang == 'zh_CN'">编号</t>
                                            <t t-else="">NO</t>
                                        </b>
                                    </th>
                                    <th class="text-left" style="width:25%">
                                        <b>
                                            <t t-if="user.lang == 'zh_CN'">Pecko 部件号</t>
                                            <t t-else="">PECKO PART NUMBER</t>
                                        </b>
                                    </th>
                                    <!--<th class="text-left" style="width:15%">-->
                                    <!--    <b>-->
                                    <!--        <t t-if="user.lang == 'zh_CN'">部件号</t>-->
                                    <!--        <t t-else="">PART NUMBER</t>-->
                                    <!--    </b>-->
                                    <!--</th>-->
                                    <!--<th class="text-left" style="width:15%">-->
                                    <!--    <b>-->
                                    <!--        <t t-if="user.lang == 'zh_CN'">描述</t>-->
                                    <!--        <t t-else="">DESCRIPTION</t>-->
                                    <!--    </b>-->
                                    <!--</th>-->
                                    <!--<th class="text-left" style="width:19%">-->
                                    <!--    <b>-->
                                    <!--        <t t-if="user.lang == 'zh_CN'">制造商</t>-->
                                    <!--        <t t-else="">MANUFACTURER</t>-->
                                    <!--    </b>-->
                                    <!--</th>-->
                                     <th class="text-center" style="width:13%">
                                        <b>
                                            <t t-if="user.lang == 'zh_CN'">预计到货日期</t>
                                            <t t-else="">ETA DATE</t>
                                        </b>
                                    </th>
                                    <th class="text-left" style="width:12%">
                                        <b>
                                            <t t-if="user.lang == 'zh_CN'">数量</t>
                                            <t t-else="">QUANTITY</t>
                                        </b>
                                    </th>
                                    <th class="text-right" style="width:10%">
                                        <b>
                                            <t t-if="user.lang == 'zh_CN'">单价</t>
                                            <t t-else="">PRICE</t>
                                        </b>
                                    </th>
                                    <!--<t t-if="o.amount_tax &gt; 0">-->
                                    <!--    <th class="text-right" style="width:10%">-->
                                    <!--        <b>-->
                                    <!--            <t t-if="user.lang == 'zh_CN'">税费</t>-->
                                    <!--            <t t-else="">TAXES</t>-->
                                    <!--        </b>-->
                                    <!--    </th>-->
                                    <!--</t>-->
                                    <th class="text-end" style="width:10%">
                                        <b>
                                            <t t-if="user.lang == 'zh_CN'">金额</t>
                                            <t t-else="">AMOUNT</t>
                                            <t groups="account.group_show_line_subtotals_tax_included">
                                                <t t-if="user.lang == 'zh_CN'">合计</t>
                                                <t t-else="">TOTAL</t>
                                            </t>
                                        </b>
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="sale_tbody" style="font-size:12px">

                                <t t-set="current_subtotal" t-value="0"/>
                                <t t-set="i" t-value="1"/>

                                <t t-foreach="o.order_line" t-as="line">

                                    <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"/>
                                    <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                                    <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                        <t t-if="not line.display_type">
                                            <td style="background-color: #f4f4f5;">
                                                <span t-field="line.line_no"/>
                                            </td>
                                            <td style="background-color: #f4f4f5;">
                                                <span t-field="line.product_id"/>
                                            </td>
                                            <!--<td style="background-color: #f4f4f5;">-->
                                            <!--    <span t-field="line.product_id.name"/>-->
                                            <!--</td>-->
                                            <!--<td style="background-color: #f4f4f5;">-->
                                            <!--    <span t-field="line.name"/>-->
                                            <!--</td>-->
                                            <!--<td style="background-color: #f4f4f5;">-->
                                            <!--    <span t-field="line.product_id.manufacturer_id"/>-->
                                            <!--</td>-->
                                            <td class="text-center" style="background-color: #f4f4f5;">
                                                <span t-field="line.date_planned" t-options="{&quot;format&quot;:&quot;dd-MM-yyyy&quot;}"/>
                                            </td>
                                            <td class="text-left" style="background-color: #f4f4f5;">
                                                <span t-field="line.product_qty"/>
                                                <span t-field="line.product_uom"/>
                                            </td>
                                            <td class="text-right" style="background-color: #f4f4f5;">
                                                <span t-field="line.price_unit"/>
                                            </td>
                                            <!--<t t-if="o.amount_tax&gt;0">-->
                                            <!--    <td style="background-color: #f4f4f5;">-->
                                            <!--        <span t-esc="line.taxes_id.code"/>-->
                                            <!--    </td>-->
                                            <!--</t>-->

                                            <td class="text-end" style="background-color: #f4f4f5;">
                                                <span t-field="line.price_subtotal"/>
                                                <span t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                            </td>
                                        </t>
                                        <t t-if="line.display_type == 'line_section'">
                                            <td name="td_section_line" colspan="99">
                                                <span t-field="line.name"/>
                                                <t t-set="i" t-value="i-1"/>
                                            </td>
                                        </t>
                                        <t t-if="line.display_type == 'line_note'">
                                            <td name="td_note_line" colspan="99">
                                                <span t-field="line.name"/>
                                                <t t-set="i" t-value="i-1"/>
                                            </td>
                                        </t>
                                    </tr>
                                    <tr style="width=100%">
                                        <td/>
                                        <td colspan="99">
                                            <span t-field="o.notes"/>
                                        </td>
                                    </tr>
                                    <t t-set="i" t-value="i+1"/>

                                </t>
                            </tbody>
                        </table>
                        <div class="row justify-content-end">
                            <div class="col-4" style="width:17%;">
                                <table class="table table-sm table-borderless" style="font-size:13px">
                                    <tr class="border-black">
                                        <td><strong>Subtotal</strong></td>
                                        <td class="text-right">
                                            <span t-field="o.amount_untaxed" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Taxes</td>
                                        <td class="text-right">
                                            <span t-field="o.amount_tax" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr class="border-black">
                                        <td><strong>Total</strong></td>
                                        <td class="text-right">
                                            <span t-field="o.amount_total" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                        <br/>

                    </div>

                </div>
            </t>
        </xpath>
    </template>

    <record id="paperformat_so" model="report.paperformat">
        <field name="name">SO Paperformat</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">48</field>
        <field name="margin_bottom">32</field>
        <field name="margin_left">6</field>
        <field name="margin_right">6</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">45</field>
        <field name="dpi">90</field>
    </record>

    <record id="paperformat_po" model="report.paperformat">
        <field name="name">PO Paperformat</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">45</field>
        <field name="margin_bottom">32</field>
        <field name="margin_left">6</field>
        <field name="margin_right">6</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">42</field>
        <field name="dpi">90</field>
    </record>

    <record id="sale.action_report_saleorder" model="ir.actions.report">
        <field name="name">Quotation / Order</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sale.report_saleorder</field>
        <field name="report_file">sale.report_saleorder</field>
        <field name="binding_model_id" ref="model_sale_order"/>
        <field name="print_report_name">
            [('draft', 'sent')].count(object.state) and ('Quotation - %s' % object.name) or ('Order - %s' % object.name)
        </field>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="pecko_so_po_report.paperformat_so"/>
    </record>

    <record id="purchase.action_report_purchase_order" model="ir.actions.report">
        <field name="name">Purchase Order</field>
        <field name="model">purchase.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">purchase.report_purchaseorder</field>
        <field name="report_file">purchase.report_purchaseorder</field>
        <field name="print_report_name">(object.state in ('draft', 'sent') and 'Request for Quotation - %s' %
            (object.name) or 'Purchase Order - %s' % (object.name))
        </field>
        <field name="binding_model_id" ref="model_purchase_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="pecko_so_po_report.paperformat_po"/>
    </record>

</odoo>