<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── List View ────────────────────────────────────────────────────── -->
    <record id="view_audit_monthly_report_list" model="ir.ui.view">
        <field name="name">audit.monthly.report.list</field>
        <field name="model">audit.monthly.report</field>
        <field name="arch" type="xml">
            <list string="Monthly Stock Audit Reports" default_order="report_date desc">
                <field name="name"/>
                <field name="report_month"/>
                <field name="report_date"/>
                <field name="generated_by"/>
                <field name="generated_on"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'posted'"
                       decoration-warning="state == 'draft'"/>
                <button name="action_download" string="Download"
                        type="object" icon="fa-download"
                        invisible="not excel_file"/>
            </list>
        </field>
    </record>

    <!-- ─── Form View ────────────────────────────────────────────────────── -->
    <record id="view_audit_monthly_report_form" model="ir.ui.view">
        <field name="name">audit.monthly.report.form</field>
        <field name="model">audit.monthly.report</field>
        <field name="arch" type="xml">
            <form string="Monthly Stock Audit Report">
                <header>
                    <button name="action_regenerate"
                            string="Regenerate Report"
                            type="object"
                            class="btn-primary"
                            icon="fa-refresh"
                            invisible="1"/>
                    <button name="action_download"
                            string="Download Excel"
                            type="object"
                            class="btn-secondary"
                            icon="fa-download"
                            invisible="not excel_file"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,posted"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group col="2">
                        <group string="Report Info">
                            <field name="report_month" readonly="1"/>
                            <field name="report_date"  readonly="1"/>
                            <field name="generated_by" readonly="1"/>
                            <field name="generated_on" readonly="1"/>
                        </group>
                        <group string="File">
                            <field name="excel_file"
                                   filename="excel_filename"
                                   widget="binary"
                                   string="Excel File"
                                   readonly="1"/>
                            <field name="excel_filename" invisible="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── Action ───────────────────────────────────────────────────────── -->
    <record id="action_audit_monthly_report" model="ir.actions.act_window">
        <field name="name">Monthly Audit Reports</field>
        <field name="res_model">audit.monthly.report</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ─── Menu ─────────────────────────────────────────────────────────── -->
    <menuitem id="menu_audit_monthly_report"
              name="Monthly Audit Reports"
              parent="stock.menu_warehouse_report"
              action="action_audit_monthly_report"
              sequence="90"
              groups="stock.group_stock_manager"/>

</odoo>
